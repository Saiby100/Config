font-family = JetBrainsMono Nerd Font
theme = One Double Dark

# On launch, reattach to the most recent tmux session; only start a new
# one if no session exists yet. `attach` targets the last-used session.
command = /bin/zsh -lc "tmux attach || tmux new-session"

# Make the Option key send Alt so Neovim's <A-...> keybinds work.
# `left` = left Option acts as Alt, right Option still types special chars
# (é, ¬, …). Use `true` if you want both Option keys to act as Alt.
macos-option-as-alt = left
